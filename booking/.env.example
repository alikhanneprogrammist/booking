# PostgreSQL — нужна поддержка расширения btree_gist (анти-овербукинг, ТЗ §4.6).
# Подойдёт любой Postgres: локальный, Docker или облако.
#   • Docker (docker-compose):  postgresql://office2020:office2020@db:5432/office2020?sslmode=disable
#   • Локальный сервер:         postgresql://user:pass@localhost:5432/office2020?sslmode=disable
#   • Облако (Neon и т.п.):     postgresql://user:pass@host/office2020?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/office2020?sslmode=disable"

# Auth.js — секрет сессии (сгенерировать: openssl rand -base64 32)
AUTH_SECRET="change-me-in-production"

# Таймзона объекта
TZ="Asia/Almaty"
